# .env.example
# Copy this file to .env and fill in your actual credentials
# DO NOT commit .env to version control

# ============================================
# SNOWFLAKE CONFIGURATION
# ============================================

# Your Snowflake account identifier (found in Snowflake console)
SNOWFLAKE_ACCOUNT=your_snowflake_account_here

# Snowflake username
SNOWFLAKE_USER=MARK

# Snowflake password (REQUIRED - this will not work without it)
SNOWFLAKE_PASSWORD=your_actual_password_here

# Database containing the analytics data
SNOWFLAKE_DATABASE=sports_db

# Schema within the database
SNOWFLAKE_SCHEMA=analytics

# Virtual warehouse to use for queries
SNOWFLAKE_WAREHOUSE=SPORTS_WH

# ============================================
# GROQ AI CONFIGURATION
# ============================================

# Your Groq API key (get from https://console.groq.com/)
# This key is used for natural language query processing
GROQ_API_KEY=your_groq_api_key_here

# Groq model to use (available options):
# - mixtral-8x7b-32768 (recommended for analytics)
# - llama2-70b-4096 (more powerful)
# - gemma-7b-it (smaller, faster)
GROQ_MODEL=mixtral-8x7b-32768

# ============================================
# FASTAPI BACKEND CONFIGURATION
# ============================================

# Host address for FastAPI server
BACKEND_HOST=0.0.0.0

# Port for FastAPI server (must not conflict with Streamlit)
BACKEND_PORT=8000

# Enable debug mode (set to False in production)
BACKEND_DEBUG=True

# CORS allowed origins (comma-separated)
# For development with local Streamlit:
CORS_ORIGINS=http://localhost:8501,http://localhost:8502

# ============================================
# STREAMLIT CONFIGURATION
# ============================================

# Streamlit server address
STREAMLIT_SERVER_ADDRESS=localhost

# Streamlit server port (must not conflict with FastAPI)
STREAMLIT_SERVER_PORT=8501

# Theme for Streamlit app (light or dark)
STREAMLIT_THEME=light

# ============================================
# APPLICATION CONFIGURATION
# ============================================

# Environment: development, staging, or production
ENVIRONMENT=development

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# API response timeout in seconds
API_TIMEOUT=30

# Maximum number of records to return in API responses
MAX_RECORDS=1000
